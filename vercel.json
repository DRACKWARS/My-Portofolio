    {
    "version": 2,
    "framework": null,
    "builds": [
        {
        "src": "package.json",
        "use": "@vercel/node"
        },
        {
        "src": "api/index.php",
        "use": "vercel-php@0.7.3"
        }
    ],
    "routes": [
        {
        "src": "/build/(.)",
        "dest": "public/build/$1"
        },
        {
        "src": "/(.)",
        "dest": "api/index.php"
        }
    ]
    }